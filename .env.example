# FarmOS environment — copy to .env.local and fill in. .env.local is gitignored.

# --- AI agent -------------------------------------------------------------
# Optional. With a key the supervisor uses real Claude (tool-runner); without,
# it falls back to the deterministic rule engine so the demo never breaks.
# ANTHROPIC_API_KEY=

# --- Real-sensor integration (Phase 2) ------------------------------------
# Leave INTEGRATION_MODE unset (or =sim) for pure simulation — the default.
# Set it to `live` + a Home Assistant URL and long-lived token to feed REAL
# sensors into the twin. Only sensors whose `ha_entity` is set in
# farm.config.yaml AND report a fresh value go LIVE; the rest keep simulating,
# so you can bring one vertical online at a time. See INTEGRATION.md.
# INTEGRATION_MODE=live
# HA_BASE_URL=http://homeassistant.local:8123
# HA_TOKEN=
# HA_POLL_MS=5000
# INTEGRATION_STALE_MS=30000

# --- Image generation (assets) --------------------------------------------
# FAL_KEY=

# --- Alerts (optional) ----------------------------------------------------
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=
